# DeepTrace — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.

# ── Core ─────────────────────────────────────────────────────────────────────
ENV=dev                          # dev | staging | prod
USE_MOCK=true                    # true = fixture data, false = real API calls

# ── LLM APIs ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...     # Claude Opus/Sonnet/Haiku
OPENAI_API_KEY=sk-...            # GPT-4.1-mini (Deep Dive Agent)
GOOGLE_API_KEY=AIza...           # Gemini 2.5 (Deep Dive Agent)
GROQ_API_KEY=gsk_...             # Groq (e.g. llama-3.3-70b)

# ── Search APIs ──────────────────────────────────────────────────────────────
TAVILY_API_KEY=tvly-...          # Primary search
LLM_CACHE_ENABLED=true           # critical — makes repeat runs free
LLM_CACHE_DIR=.llm_cache
# BRAVE_SEARCH_API_KEY=BSA...     # Backup search

# ── LangSmith ────────────────────────────────────────────────────────────────
LANGCHAIN_API_KEY=lsv2_pt_...    # LangSmith API key
LANGCHAIN_PROJECT=DeepTrace      # deeptrace-dev | deeptrace-staging | deeptrace-prod
LANGCHAIN_TRACING_V2=false       # set true to enable tracing
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ── Neo4j ────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=deeptrace123
NEO4J_DATABASE=neo4j

# ── Checkpointing ────────────────────────────────────────────────────────────
CHECKPOINT_DB_PATH=.checkpoints/deeptrace.db

# ── Audit logging ───────────────────────────────────────────────────────────
AUDIT_LOG_DIR=.audit_logs

# ── Graph artifact persistence ──────────────────────────────────────────────
GRAPH_ARTIFACT_DIR=.graph_artifacts

# ── Rate limiting ───────────────────────────────────────────────────────────
LLM_MAX_RETRIES=3
LLM_RETRY_BASE_DELAY=1.0
LLM_REQUESTS_PER_MIN=50
GROQ_REQUESTS_PER_MIN=30
GEMINI_REQUESTS_PER_MIN=10
OPENAI_REQUESTS_PER_MIN=30

# ── Search feature toggles ──────────────────────────────────────────────────
HAIKU_WEB_SEARCH_ENABLED=true
MAX_SEARCH_RESULTS_PER_QUERY=5

# ── Entity canonicalization ─────────────────────────────────────────────────
ENTITY_SIMILARITY_THRESHOLD=0.85
